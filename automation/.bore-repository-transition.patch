diff --git a/config-charcoal b/config-charcoal
index 146efb4..2c9b468 100755
--- a/config-charcoal
+++ b/config-charcoal
@@ -16,6 +16,10 @@ CONFIG_CPU_SUP_ZHAOXIN=n
 # Enable lru_marie 
 CONFIG_LRU_MARIE=y
 
+# Enable BORE by default. The patch also defaults sched_bore to 1 at runtime.
+CONFIG_SCHED_BORE=y
+CONFIG_MIN_BASE_SLICE_NS=2000000
+
 # ZRAM-IR: LZ4 is the primary SteamOS swap compressor. The packaged udev
 # helper configures ZSTD as the priority-1 recompressor before zram is sized.
 CONFIG_ZRAM_DEF_COMP_LZ4=y
